menuconfig MOTOR
	bool "Motor Control Drivers"
	default n
	help
	  Enable support for motor control drivers.

if MOTOR

config MOTOR_TMC5240
	depends on SPI
	bool "Enable TMC5240 motor driver"
	default n

config TMC_API_VERSION
	string "TMC-API version tag"
	default "3.11.4"
	depends on MOTOR_TMC5240
	help
	  Git tag or branch name for TMC-API.
	  Checked against the submodule, then the shared cache, then fetched.

config MOTOR_IIO_TMC5240
	select MOTOR_TMC5240
	bool "Enable TMC5240 IIO driver"
	default n

config MOTOR_TMC7300
	depends on UART
	select GPIO
	bool "Enable TMC7300 motor driver"
	default n

endif # MOTOR
