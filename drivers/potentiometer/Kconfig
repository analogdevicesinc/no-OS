	select GPIO
	bool "Enable AD5171 digital potentiometer driver"
	default n

config POTENTIOMETER_AD5242
	depends on SPI || I2C
	select GPIO
	bool "Enable AD5242 digital potentiometer driver"
	default n

config POTENTIOMETER_AD5246
	depends on SPI || I2C
