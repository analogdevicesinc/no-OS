menuconfig POTENTIOMETER
	bool "Digital Potentiometer Drivers"
	default n
	help
	  Enable support for digital potentiometer drivers.

if POTENTIOMETER

config POTENTIOMETER_AD5110
	depends on I2C
	bool "Enable AD5110 digital potentiometer driver"
	default n

config POTENTIOMETER_AD514X
	depends on SPI || I2C
	select GPIO
	bool "Enable AD514x digital potentiometer driver (AD5141/AD5142/AD5143/AD5144)"
	default n

