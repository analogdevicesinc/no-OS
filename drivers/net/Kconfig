menuconfig NET
    bool "Networking Drivers"
    default n
    help
      Enable support for networking drivers.

if NET

config ADIN1110
    depends on SPI
    select GPIO
    select OA_TC6
    bool "Enable the ADIN1110 driver"
    default n

config ADIN1320
    select MDIO_SPI
    bool "Enable the ADIN1320 driver"
    default n
    help
      Enable the ADIN1320 Ethernet PHY driver. Communicates with the PHY
      over MDIO carried on a SPI bus (MDIO_SPI).

config NET_ADIN1300
    depends on GPIO
    bool "Enable the ADIN1300 driver"
    default n

config NET_IIO_ADIN1300
    select NET_ADIN1300
    bool "Enable the ADIN1300 IIO driver"
    default n

config NET_MAX24287
    depends on GPIO
    bool "Enable the MAX24287 driver"
    default n

config NET_IIO_MAX24287
    select NET_MAX24287
    bool "Enable the MAX24287 IIO driver"
    default n

config NET_MDIO_BITBANG
    depends on GPIO
    bool "Enable the MDIO bit-bang driver"
    default n

config MDIO_SPI
    depends on SPI
    select MDIO
    bool "Enable the MDIO over SPI driver"
    default n
    help
      Enable the MDIO-over-SPI transport driver, which implements the
      no_os_mdio API on top of a SPI bus.

config ADIN1140
    depends on SPI
    select GPIO
    select OA_TC6
    bool "Enable the ADIN1140 10BASE-T1S MACPHY driver"
    default n

config OA_TC6
    depends on SPI
    bool "Enable the Open Alliance TC6 protocol library"
    default n

source "drivers/net/oa_tc6/Kconfig"

endif
