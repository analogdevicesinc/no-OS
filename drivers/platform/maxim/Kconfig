menuconfig MAXIM
	bool "Maxim Platform Drivers"
	default n
	help
	  Enable support for Maxim platform drivers.

	  This section contains low-level platform drivers for Maxim
	  microcontrollers including GPIO, SPI, I2C, UART, PWM, DMA,
	  interrupt handling, USB UART, RTC, Timer, and other peripheral
	  drivers across multiple Maxim chip families.

if MAXIM

config GPIO_MAXIM
	bool "Enable Maxim GPIO driver"
	depends on GPIO
	default n
	help
	  Enable Maxim-specific GPIO driver implementation.

config GPIO_IRQ_MAXIM
	bool "Enable Maxim GPIO IRQ driver"
	depends on GPIO && IRQ
	default n
	help
	  Enable Maxim-specific GPIO interrupt driver implementation.

config I2C_MAXIM
	bool "Enable Maxim I2C driver"
	depends on I2C
	default n
	help
	  Enable Maxim-specific I2C driver implementation.

config SPI_MAXIM
	bool "Enable Maxim SPI driver"
	depends on SPI
	default n
	help
	  Enable Maxim-specific SPI driver implementation.

config SPI_GPIO_MAXIM
	bool "Enable Maxim bit-banged (GPIO) SPI driver"
	depends on SPI && GPIO_MAXIM
	default n
	help
	  Enable a software SPI master implemented with direct GPIO register
	  toggling (no_os_spi platform ops). Pin-parameterized and safe to share a
	  bus between two cores: it drives SCLK/MOSI only while a transfer is in
	  flight and leaves them high-Z otherwise, so an idle core does not fight
	  the active one. Used by the MAX78000 dual-core IMU example.

config SYS_MAXIM
	bool "Enable Maxim system-level helpers"
	default n
	help
	  Enable shared MAX78000 system helpers (maxim_sys.c), including the
	  read-modify-write __wrap_MXC_SYS_Reset_Periph() replacement for the SDK's
	  destructive peripheral-reset store. Requires the corresponding
	  "-Wl,--wrap=MXC_SYS_Reset_Periph" link option.

config UART_MAXIM
	bool "Enable Maxim UART driver"
	depends on UART
	default n
	help
	  Enable Maxim-specific UART driver implementation.

config UART_STDIO_MAXIM
	bool "Enable Maxim UART STDIO driver"
	depends on UART
	default n
	help
	  Enable Maxim-specific UART STDIO driver implementation.

config USB_UART_MAXIM
	bool "Enable Maxim USB UART driver"
	default n
	help
	  Enable Maxim-specific USB UART driver implementation.
	  Platform-specific USB UART functionality.

config IRQ_MAXIM
	bool "Enable Maxim IRQ driver"
	depends on IRQ
	default n
	help
	  Enable Maxim-specific interrupt handling driver.

config PWM_MAXIM
	bool "Enable Maxim PWM driver"
	depends on PWM
	default n
	help
	  Enable Maxim-specific PWM driver implementation.
	  Requires CONFIG_PWM=y to be enabled.

config TIMER_MAXIM
	bool "Enable Maxim Timer driver"
	depends on TIMER
	default n
	help
	  Enable Maxim-specific Timer driver implementation.
	  Requires CONFIG_TIMER=y to be enabled.

config RTC_MAXIM
	bool "Enable Maxim RTC driver"
	depends on RTC
	default n
	help
	  Enable Maxim-specific RTC driver implementation.
	  Requires CONFIG_RTC=y to be enabled.

config TRNG_MAXIM
	bool "Enable Maxim TRNG driver"
	depends on TRNG
	default n
	help
	  Enable Maxim-specific TRNG (True Random Number Generator) driver.
	  Requires CONFIG_TRNG=y to be enabled.

config DMA_MAXIM
	bool "Enable Maxim DMA driver"
	depends on DMA
	default n
	help
	  Enable Maxim-specific DMA driver implementation.

config IPC_MAXIM
	bool "Enable Maxim inter-processor communication (IPC) driver"
	select IPC
	default n
	help
	  Enable the SEMA-backed inter-processor communication driver: core-to-core
	  doorbell interrupts (irq0/irq1) and hardware mailbox registers for
	  notifications between CPU0 (Arm) and CPU1 (RISC-V). Implements the generic
	  no_os_ipc API (include/no_os_ipc.h).

config COPROCESSOR_MAXIM
	bool "Enable Maxim coprocessor (CPU1) lifecycle driver"
	depends on IPC_MAXIM
	default n
	help
	  Enable boot/halt lifecycle control for the auxiliary processor core
	  (e.g., RISC-V RV32 CPU1 on MAX78000). Also provides access to the
	  cross-core IPC shared memory interface (maxim_ipc_shared.h).

endif # MAXIM
