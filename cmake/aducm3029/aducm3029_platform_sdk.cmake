# ADuCM3029 platform SDK configuration.
#
# The ADuCM3029 project artifacts — startup_ADuCM3029.c, reset_ADuCM3029.S,
# system_ADuCM3029.c, the pinmux GeneratedSources, adi_initialize.c and the
# ADuCM3029.ld linker script — are produced by CrossCore Embedded Studio (CCES)
# headless tools. It follows the same shape as cmake/stm32/stm32_platform_sdk.cmake
# (generate-once, stamp-gated, then consume the generated sources).

# Resolve the pinmux_config.c "hardware" file for the current project.
# Sets PINMUX_FILE in the caller's scope.
function(resolve_aducm_pinmux_file)
	if(DEFINED CONFIG_ADUCM_PINMUX_PATH AND NOT "${CONFIG_ADUCM_PINMUX_PATH}" STREQUAL "")
		if(IS_ABSOLUTE "${CONFIG_ADUCM_PINMUX_PATH}")
			set(PINMUX_FILE "${CONFIG_ADUCM_PINMUX_PATH}" PARENT_SCOPE)
		else()
			set(PINMUX_FILE "${CMAKE_SOURCE_DIR}/projects/${NO_OS_PROJECT_NAME}/${CONFIG_ADUCM_PINMUX_PATH}" PARENT_SCOPE)
		endif()
	else()
		set(PINMUX_FILE "${CMAKE_SOURCE_DIR}/projects/${NO_OS_PROJECT_NAME}/pinmux_config.c" PARENT_SCOPE)
	endif()
endfunction()

# Determine whether the CCES project needs to be (re)generated by comparing the
# current pinmux file sha1 + CCES path against a stamp written after the last
# successful generation. The generated linker script must also still exist.
# Returns NEED_REGEN (TRUE/FALSE) in the caller's scope.
function(aducm_check_cces_stale PINMUX_FILE PROJECT_DIR STAMP_FILE)
	set(NEED_REGEN TRUE PARENT_SCOPE)

	if(EXISTS "${PINMUX_FILE}")
		file(SHA1 "${PINMUX_FILE}" _pinmux_hash)
	else()
		set(_pinmux_hash "MISSING")
	endif()
	set(_current "${_pinmux_hash}:${CCES_HOME}")

	if(EXISTS "${STAMP_FILE}" AND EXISTS "${PROJECT_DIR}/RTE/Device/ADuCM3029/ADuCM3029.ld")
		file(READ "${STAMP_FILE}" _stored)
		string(STRIP "${_stored}" _stored)
		if("${_current}" STREQUAL "${_stored}")
			set(NEED_REGEN FALSE PARENT_SCOPE)
			return()
		endif()
		message(STATUS "CCES regeneration needed (pinmux or CCES changed)")
	endif()
endfunction()

function(aducm_write_cces_stamp PINMUX_FILE STAMP_FILE)
	if(EXISTS "${PINMUX_FILE}")
		file(SHA1 "${PINMUX_FILE}" _pinmux_hash)
	else()
		set(_pinmux_hash "MISSING")
	endif()
	file(WRITE "${STAMP_FILE}" "${_pinmux_hash}:${CCES_HOME}")
endfunction()

function(config_aducm3029_sdk BUILD_TARGET)
	# Locate the CCES launcher (Linux: cces, Windows: ccesc), bundled under the
	# CCES Eclipse directory.
	if(CMAKE_HOST_SYSTEM_NAME STREQUAL "Windows")
		set(_cces_names ccesc)
	else()
		set(_cces_names cces)
	endif()
	find_program(CCES_LAUNCHER NAMES ${_cces_names} HINTS "${CCES_EXE}")
	if(NOT CCES_LAUNCHER)
		message(FATAL_ERROR
			"CCES launcher (${_cces_names}) not found under ${CCES_EXE}. "
			"Check the CCES installation.")
	endif()

	resolve_aducm_pinmux_file()
	if(NOT EXISTS "${PINMUX_FILE}")
		message(FATAL_ERROR
			"ADuCM3029 pinmux file not found: ${PINMUX_FILE}. "
			"Provide projects/${NO_OS_PROJECT_NAME}/pinmux_config.c or set "
			"CONFIG_ADUCM_PINMUX_PATH.")
	endif()

	# CCES workspace + generated project layout (WORKSPACE / PROJECT_BUILD=app).
	set(CCES_WORKSPACE "${CMAKE_CURRENT_BINARY_DIR}/${BOARD}_cces")
	set(CCES_PROJECT_NAME "app")
	set(CCES_PROJECT_DIR "${CCES_WORKSPACE}/${CCES_PROJECT_NAME}")
	set(STAMP_FILE "${CCES_WORKSPACE}/.cces_stamp")

	set(PLATFORM_TOOLS "${NO_OS_DIR}/tools/scripts/platform/aducm3029")

	aducm_check_cces_stale("${PINMUX_FILE}" "${CCES_PROJECT_DIR}" "${STAMP_FILE}")

	if(NEED_REGEN)
		# CCES headless project generation is nondeterministic: projectcreate +
		# `addaddin -regensrc` reports success but intermittently fails to emit
		# the RTE Device sources (ADuCM3029.ld, reset/system, adi_*_config.h),
		# and re-running addaddin on the same project does not reliably recover.
		# So retry the entire create+regen sequence from a clean workspace until
		# the linker script appears (the "fully generated" signal). The PinMux
		# XML warning these steps print is benign (present even in good runs).
		set(_ld_path "${CCES_PROJECT_DIR}/RTE/Device/ADuCM3029/ADuCM3029.ld")
		set(_max_attempts 5)
		set(_generated FALSE)

		foreach(_attempt RANGE 1 ${_max_attempts})
			# Full workspace cleanup each attempt: stale CCES metadata (which
			# tracks the imported project by name) would otherwise make a repeat
			# projectcreate fail with "Failed to create project".
			file(REMOVE_RECURSE "${CCES_WORKSPACE}")
			file(MAKE_DIRECTORY "${CCES_WORKSPACE}")

			message(STATUS "Generating ADuCM3029 CCES project (attempt ${_attempt}/${_max_attempts})...")
			execute_process(
				COMMAND ${CCES_LAUNCHER} -nosplash
					-application com.analog.crosscore.headlesstools
					-command projectcreate
					-data ${CCES_WORKSPACE}
					-project ${CCES_PROJECT_DIR}
					-project-name ${CCES_PROJECT_NAME}
					-processor ADuCM3029
					-type Executable
					-revision any
					-language C
					-config Release
					-remove-switch linker -specs=rdimon.specs
				OUTPUT_VARIABLE _create_out
				ERROR_VARIABLE _create_err
			)

			# Overwrite system.rteconfig with the one enabling all DFP features no-OS needs.
			configure_file(
				"${PLATFORM_TOOLS}/system.rteconfig"
				"${CCES_PROJECT_DIR}/system.rteconfig"
				COPYONLY
			)

			execute_process(
				COMMAND ${CCES_LAUNCHER} -nosplash
					-application com.analog.crosscore.headlesstools
					-command addaddin
					-data ${CCES_WORKSPACE}
					-project ${CCES_PROJECT_NAME}
					-id com.analog.crosscore.ssldd.pinmux.component
					-version latest
					-regensrc
				OUTPUT_VARIABLE _regen_out
				ERROR_VARIABLE _regen_err
			)

			if(EXISTS "${_ld_path}")
				set(_generated TRUE)
				break()
			endif()

			message(STATUS "ADuCM3029 RTE sources not generated on attempt ${_attempt}; retrying...")
		endforeach()

		if(NOT _generated)
			# Surface the last attempt's output to aid debugging.
			if(_create_out)
				message(STATUS "${_create_out}")
			endif()
			if(_regen_out)
				message(STATUS "${_regen_out}")
			endif()
			if(_regen_err)
				message(STATUS "${_regen_err}")
			endif()
			message(FATAL_ERROR
				"CCES failed to generate the ADuCM3029 RTE sources (no ${_ld_path}) "
				"after ${_max_attempts} attempts. See the CCES output above.")
		endif()

		# The stock startup_ADuCM3029.c has compile errors; replace with the patch.
		configure_file(
			"${PLATFORM_TOOLS}/startup_ADuCM3029_patch.c"
			"${CCES_PROJECT_DIR}/RTE/Device/ADuCM3029/startup_ADuCM3029.c"
			COPYONLY
		)

		# Install the project's pinmux configuration into the generated sources.
		configure_file(
			"${PINMUX_FILE}"
			"${CCES_PROJECT_DIR}/system/pinmux/GeneratedSources/pinmux_config.c"
			COPYONLY
		)

		# Validate the remaining expected generated artifacts before relying on them.
		foreach(_required
			"RTE/Device/ADuCM3029/reset_ADuCM3029.S"
			"RTE/Device/ADuCM3029/system_ADuCM3029.c"
			"system/adi_initialize.c")
			if(NOT EXISTS "${CCES_PROJECT_DIR}/${_required}")
				message(FATAL_ERROR
					"Expected CCES-generated file missing: ${CCES_PROJECT_DIR}/${_required}. "
					"CCES project generation may have produced an unexpected layout. "
					"See the CCES output above.")
			endif()
		endforeach()

		aducm_write_cces_stamp("${PINMUX_FILE}" "${STAMP_FILE}")
	endif()

	# Generated startup/system/reset/pinmux sources compile into the executable.
	set(_rte_dir "${CCES_PROJECT_DIR}/RTE/Device/ADuCM3029")
	target_sources(${BUILD_TARGET} PRIVATE
		${_rte_dir}/startup_ADuCM3029.c
		${_rte_dir}/system_ADuCM3029.c
		${_rte_dir}/reset_ADuCM3029.S
		${CCES_PROJECT_DIR}/system/adi_initialize.c
		${CCES_PROJECT_DIR}/system/pinmux/GeneratedSources/pinmux_config.c
	)

	# Generated headers (RTE config, device config) needed by the DFP sources.
	target_include_directories(no-os PUBLIC
		${_rte_dir}
		${CCES_PROJECT_DIR}/RTE
		${CCES_PROJECT_DIR}/system
	)

	# Rework the generated linker script so the WiFi/IIOD workload can use as
	# much of the chip's 64 KiB SRAM as possible.
	#
	# The reset handler clears INSTREN (-DADI_DISABLE_INSTRUCTION_SRAM, see
	# toolchain.cmake), which remaps the 32 KiB of otherwise-unused instruction
	# SRAM as data SRAM (SRAM MODE2). The chip then exposes two 32 KiB data
	# banks that are NOT contiguous: DSRAM_A at 0x20000000 and DSRAM_B at
	# 0x20040000. newlib's malloc/_sbrk can only grow one contiguous region, so
	# the heap cannot straddle the gap - it must live entirely in one bank.
	#
	# The stock script puts .data/.bss in DSRAM_B and heap+stack in DSRAM_A,
	# which caps the heap at "32 KiB minus data/bss/stack". Instead:
	#   1. widen both banks 16k -> 32k,
	#   2. move .data/.bss into DSRAM_A (alongside the stack), and
	#   3. give the whole of DSRAM_B to the heap.
	# The fixed footprint (.data + .bss + stack ~= 18 KiB) then lives in
	# DSRAM_A with room to spare, and the heap gets a full contiguous 32 KiB
	# bank to itself (see __HEAP_SIZE in the platform CMakeLists).
	#
	# Idempotent: the region swaps are anchored on symbols that only appear
	# once and flip B->A / A->B, and the length/assert edits match strings that
	# are gone after the first run, so re-running on a patched script is a no-op.
	set(_ld_file "${_rte_dir}/ADuCM3029.ld")
	file(READ "${_ld_file}" _ld_contents)
	# 1. Both banks physically span 32 KiB.
	string(REGEX REPLACE
		"(DSRAM_A[^\n]*ORIGIN[ \t]*=[ \t]*0x20000000,[ \t]*LENGTH[ \t]*=[ \t]*)16k"
		"\\132k" _ld_contents "${_ld_contents}")
	string(REGEX REPLACE
		"(DSRAM_B[^\n]*ORIGIN[ \t]*=[ \t]*0x20040000,[ \t]*LENGTH[ \t]*=[ \t]*)16k"
		"\\132k" _ld_contents "${_ld_contents}")
	# 2. .data and .bss move from DSRAM_B to DSRAM_A (anchored on their end
	#    symbols so only these two output sections are retargeted).
	string(REGEX REPLACE
		"(__data_end__[^}]*})[ \t]*>[ \t]*DSRAM_B"
		"\\1 > DSRAM_A" _ld_contents "${_ld_contents}")
	string(REGEX REPLACE
		"(__bss_end__[^}]*})[ \t]*>[ \t]*DSRAM_B"
		"\\1 > DSRAM_A" _ld_contents "${_ld_contents}")
	# 3. The heap moves from DSRAM_A to DSRAM_B (gets the whole bank).
	string(REGEX REPLACE
		"(__HeapLimit[^}]*})[ \t]*>[ \t]*DSRAM_A"
		"\\1 > DSRAM_B" _ld_contents "${_ld_contents}")
	# 4. The stock ASSERT guarded heap+stack sharing DSRAM_A. Now DSRAM_A holds
	#    data/bss/stack and DSRAM_B holds the heap, so guard each bank instead.
	string(REGEX REPLACE
		"ASSERT\\(__StackLimit >= __HeapLimit[^\n]*\n"
		"ASSERT(__StackLimit >= __bss_end__, \"region DSRAM_A overflowed with stack\")\n\tASSERT(__HeapLimit <= ORIGIN(DSRAM_B) + LENGTH(DSRAM_B), \"region DSRAM_B overflowed with heap\")\n"
		_ld_contents "${_ld_contents}")
	file(WRITE "${_ld_file}" "${_ld_contents}")

	# Linker script (generated per-project).
	target_link_options(${BUILD_TARGET} PRIVATE -T${_rte_dir}/ADuCM3029.ld)

	# OpenOCD config for flash/debug (vars set in toolchain.cmake).
	generate_openocd_config()
endfunction()
