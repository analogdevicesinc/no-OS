function(no_os_sources_ifdef feature_toggle source)
  if(${feature_toggle})
    if(NO_OS_VERBOSE)
      message(STATUS "Adding ${source}")
    endif()
    target_sources(no-os PRIVATE ${source} ${ARGN})
  endif()
endfunction()

function(no_os_sources_dir_ifdef feature_toggle dir)
  if(${feature_toggle})
    file(GLOB _sources "${dir}/*.c")
    if(NO_OS_VERBOSE)
      foreach(_src ${_sources})
        message(STATUS "Adding ${_src}")
      endforeach()
    endif()
    target_sources(no-os PRIVATE ${_sources})
  endif()
endfunction()

function(no_os_sources_dir_recurse_ifdef feature_toggle dir)
  if(${feature_toggle})
    file(GLOB_RECURSE _sources "${dir}/*.c")
    if(NO_OS_VERBOSE)
      foreach(_src ${_sources})
        message(STATUS "Adding ${_src}")
      endforeach()
    endif()
    target_sources(no-os PRIVATE ${_sources})
  endif()
endfunction()

function(no_os_include_dir_ifdef feature_toggle include_dir)
  if(${feature_toggle})
    if(NO_OS_VERBOSE)
      message(STATUS "Adding ${include_dir}")
    endif()
    target_include_directories(no-os PUBLIC ${include_dir})
  endif()
endfunction()

function(no_os_include_dir_recurse_ifdef feature_toggle dir)
  if(${feature_toggle})
    file(GLOB_RECURSE _headers "${dir}/*.h")
    set(_dirs "")
    foreach(_hdr ${_headers})
      get_filename_component(_hdr_dir "${_hdr}" DIRECTORY)
      list(APPEND _dirs "${_hdr_dir}")
    endforeach()
    list(REMOVE_DUPLICATES _dirs)
    if(NO_OS_VERBOSE)
      foreach(_d ${_dirs})
        message(STATUS "Adding include ${_d}")
      endforeach()
    endif()
    target_include_directories(no-os PUBLIC ${_dirs})
  endif()
endfunction()
