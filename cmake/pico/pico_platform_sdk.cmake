# Pico (RP2040) platform SDK configuration.
#
# config_pico_sdk(BUILD_TARGET) is invoked by config_platform_sdk() (see
# cmake/project_utils.cmake) from the project's CMakeLists. It replicates the
# parts of the pico-sdk's own CMake build that the no-OS Make build performs by
# hand in tools/scripts/pico.mk:
#   - generate the SDK headers normally produced at configure time
#     (pico/version.h, pico/config_autogen.h) and the linker fragment
#     (pico_flash_region.ld),
#   - compile, checksum and link the second-stage bootloader (boot2),
#   - point the linker at the SDK's memmap_default.ld,
#   - optionally convert the ELF to UF2 with picotool.

# Pico board flash size (default 2 MiB for the Raspberry Pi Pico). The SDK's
# memmap_default.ld INCLUDEs a generated pico_flash_region.ld that defines the
# FLASH region.
if(NOT DEFINED PICO_FLASH_SIZE_BYTES)
        set(PICO_FLASH_SIZE_BYTES 2097152)
endif()

# Generate the SDK headers and linker fragment at configure time. These mirror
# the pico_genheaders rules in pico.mk. They are written under
# ${CMAKE_BINARY_DIR}/build/generated so the include path added in
# drivers/platform/pico/CMakeLists.txt (pico_base) and the -L path below resolve.
function(pico_generate_sdk_headers)
        set(_gen_base "${CMAKE_BINARY_DIR}/build/generated")
        set(_pico_base "${_gen_base}/pico_base")

        # pico/version.h from version.h.in + pico_sdk_version.cmake.
        include("${PICO_SDK_PATH}/pico_sdk_version.cmake")
        configure_file(
                "${PICO_SDK_PATH}/src/common/pico_base_headers/include/pico/version.h.in"
                "${_pico_base}/pico/version.h"
                @ONLY)

        # pico/config_autogen.h: the board header is enough for an rp2040 build.
        file(WRITE "${_pico_base}/pico/config_autogen.h"
                "// AUTOGENERATED BY no-OS pico_platform_sdk.cmake - DO NOT EDIT\n"
                "#include \"boards/pico.h\"\n")

        # pico_flash_region.ld defines the FLASH region INCLUDEd by
        # memmap_default.ld.
        file(WRITE "${_gen_base}/pico_flash_region.ld"
                "FLASH(rx) : ORIGIN = 0x10000000, LENGTH = ${PICO_FLASH_SIZE_BYTES}\n")
endfunction()

# Build the second-stage bootloader and attach it to BUILD_TARGET.
#
# compile_time_choice.S is compiled and linked with boot_stage2.ld into a tiny
# ELF, objcopy'd to a raw binary, then run through pad_checksum to emit a .boot2
# assembly section. That assembly is compiled and linked into the application;
# memmap_default.ld places the .boot2 section at the start of flash.
function(pico_add_boot_stage2 BUILD_TARGET)
        set(_boot_dir "${PICO_SDK_PATH}/src/rp2040/boot_stage2")
        set(_gen_base "${CMAKE_BINARY_DIR}/build/generated")
        set(_boot_build "${_gen_base}/boot_stage2")
        file(MAKE_DIRECTORY "${_boot_build}")

        set(_boot_elf "${_boot_build}/boot2.elf")
        set(_boot_bin "${_boot_build}/boot2.bin")
        set(_boot_asm "${_boot_build}/boot2.S")

        # Boot stage 2 builds for cortex-m0plus and needs the low-level pico
        # headers (ported from pico.mk BOOT_INCLUDE/BOOT_DEFINES).
        set(_boot_incs
                "${_gen_base}/pico_base"
                "${PICO_SDK_PATH}/src/rp2_common/cmsis/include"
                "${_boot_dir}/asminclude"
                "${PICO_SDK_PATH}/src/rp2040/hardware_regs/include"
                "${PICO_SDK_PATH}/src/rp2_common/hardware_base/include"
                "${PICO_SDK_PATH}/src/common/pico_base_headers/include"
                "${PICO_SDK_PATH}/src/boards/include"
                "${PICO_SDK_PATH}/src/rp2_common/pico_platform_common/include"
                "${PICO_SDK_PATH}/src/rp2_common/pico_platform_compiler/include"
                "${PICO_SDK_PATH}/src/rp2_common/pico_platform_panic/include"
                "${PICO_SDK_PATH}/src/rp2_common/pico_platform_sections/include"
                "${PICO_SDK_PATH}/src/rp2040/pico_platform/include"
                "${_boot_dir}/include")
        set(_boot_inc_flags "")
        foreach(_d ${_boot_incs})
                list(APPEND _boot_inc_flags "-I${_d}")
        endforeach()
        set(_boot_defs
                -DPICO_BOARD="pico" -DPICO_BUILD=1 -DPICO_NO_HARDWARE=0
                -DPICO_ON_DEVICE=1 -DPICO_RP2040=1)

        add_custom_command(
                OUTPUT "${_boot_asm}"
                COMMAND ${CMAKE_C_COMPILER} -mcpu=cortex-m0plus -mthumb
                        -Wl,--build-id=none --specs=nosys.specs -nostartfiles
                        ${_boot_inc_flags} ${_boot_defs}
                        -T${_boot_dir}/boot_stage2.ld
                        ${_boot_dir}/compile_time_choice.S
                        -o ${_boot_elf}
                COMMAND ${CMAKE_OBJCOPY} -O binary ${_boot_elf} ${_boot_bin}
                COMMAND ${VENV_PYTHON_EXE} ${_boot_dir}/pad_checksum
                        -s 0xffffffff ${_boot_bin} ${_boot_asm}
                DEPENDS ${_boot_dir}/compile_time_choice.S
                        ${_boot_dir}/boot_stage2.ld
                COMMENT "Building pico boot stage 2"
                VERBATIM)

        # The .boot2 section is placed by memmap_default.ld.
        target_sources(${BUILD_TARGET} PRIVATE "${_boot_asm}")
endfunction()

function(config_pico_sdk BUILD_TARGET)
        pico_generate_sdk_headers()
        pico_add_boot_stage2(${BUILD_TARGET})

        # Link against the SDK's default memory map; -L resolves the generated
        # pico_flash_region.ld that it INCLUDEs.
        target_link_options(${BUILD_TARGET} PRIVATE
                -L${CMAKE_BINARY_DIR}/build/generated
                -T${PICO_SDK_PATH}/src/rp2_common/pico_crt0/rp2040/memmap_default.ld)

        # OpenOCD configuration for the cmsis-dap (picoprobe) probe. Set as
        # locals and emit openocd.cfg here (mirroring config_stm32_sdk), since a
        # later generate_openocd_config() from post_build_config() runs in the
        # project scope where these are not visible.
        #
        # The "halted" event handler clears TIMER_DBGPAUSE (TIMER_BASE +0x2c) on
        # every core halt so busy_wait_*() loops do not spin forever under debug
        # (the RP2040 timer is paused while a core is halted by default). See the
        # start_openocd target in tools/scripts/pico.mk for the rationale.
        set(OPENOCD_INTERFACE "interface/cmsis-dap.cfg")
        set(OPENOCD_CHIPNAME "rp2040")
        set(OPENOCD_TARGETCFG "target/rp2040.cfg")
        set(OPENOCD_EXTRA_COMMANDS "adapter speed 5000")
        set(OPENOCD_POST_COMMANDS
                "rp2040.core0 configure -event halted { mww 0x4005402c 0 }")
        generate_openocd_config()

        # Optional UF2 image via picotool (not vendored). Skip with a status
        # message when unavailable, matching the Make build.
        find_program(PICOTOOL_PATH NAMES picotool DOC "Path to picotool")
        if(PICOTOOL_PATH)
                add_custom_command(
                        TARGET ${BUILD_TARGET}
                        POST_BUILD
                        COMMAND ${PICOTOOL_PATH} uf2 convert -t elf
                                $<TARGET_FILE:${BUILD_TARGET}>
                                -t uf2 ${CMAKE_RUNTIME_OUTPUT_DIRECTORY}/${BUILD_TARGET}.uf2
                                --family rp2040
                        COMMENT "Generating ${BUILD_TARGET}.uf2"
                        VERBATIM)
        else()
                message(STATUS
                        "picotool not found; the .uf2 image will not be generated "
                        "(.elf and .hex still build). Install picotool or set "
                        "-DPICOTOOL_PATH=... to enable it.")
        endif()
endfunction()
