{
    "configurations": [
        {
            "name": "@PLATFORM@-@TARGET@",
            "compileCommands": "${workspaceFolder}/@CMAKE_BUILD_DIR@/compile_commands.json",
            "includePath": [
                "${workspaceFolder}/@CMAKE_BUILD_DIR@/build",
                "${workspaceFolder}/include",
                "${workspaceFolder}/drivers/**",
                "${workspaceFolder}/iio/**"@PLATFORM_INCLUDE_PATHS@
            ],
            "browse": {
                "path": [
                    "${workspaceFolder}/@CMAKE_BUILD_DIR@",
                    "${workspaceFolder}/include",
                    "${workspaceFolder}/drivers",
                    "${workspaceFolder}/iio",
                    "${workspaceFolder}/projects",
                    "${workspaceFolder}/util"@PLATFORM_INCLUDE_PATHS@
                ]
            },
            "compilerPath": "@CMAKE_C_COMPILER@",
            "cStandard": "c11",
            "cppStandard": "c++17",
            "intelliSenseMode": "@INTELLISENSE_MODE@"
        }
    ],
    "version": 4
}
