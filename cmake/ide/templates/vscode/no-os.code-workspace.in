{
    "folders": [
        {
            "name": "@NO_OS_PROJECT_NAME@ [project]",
            "path": "projects/@NO_OS_PROJECT_NAME@"
        },
@WORKSPACE_BUILD_FOLDER@        {
            "name": "no-OS",
            "path": "."
        }
    ],
    "settings": {
        "files.exclude": {
            "projects/@NO_OS_PROJECT_NAME@": true
        },
        "cortex-debug.gdbPath": "@GDB_PATH@",
        "cortex-debug.openocdPath": "@OPENOCD_PATH@"
    }
}
