menu "Network Configuration"
	depends on LWIP || W5500 || WIFI

config NO_OS_NET
	bool "Use the new no_os_net / no_os_socket interfaces"
	default n
	depends on LWIP || W5500 || WIFI
	help
	  Select the new networking HAL (no_os_net + no_os_socket) instead of
	  the legacy network_interface / tcp_socket stack. Mutually exclusive
	  with the legacy path: when enabled, the matching adapter (network/lwip,
	  network/w5500 or network/wifi) is compiled and the legacy
	  NO_OS_*_NETWORKING macro is left undefined.

config NO_OS_STATIC_IP
	bool "Use static IP address"
	default n
	help
	  Use a static IP address instead of DHCP. When enabled,
	  NO_OS_IP, NO_OS_NETMASK and NO_OS_GATEWAY must be configured.

config NO_OS_IP
	string "IP address"
	depends on NO_OS_STATIC_IP

config NO_OS_NETMASK
	string "Netmask"
	depends on NO_OS_STATIC_IP

config NO_OS_GATEWAY
	string "Gateway"
	depends on NO_OS_STATIC_IP

config NO_OS_DOMAIN_NAME
	string "mDNS host name"
	default "analog"
	depends on LWIP
	help
	  Host name advertised by the lwIP mDNS responder (the board is
	  reachable as <name>.local). Defaults to "analog".

config NO_OS_LWIP_INIT_ONETIME
	bool "Initialize LWIP only once"
	default n
	depends on LWIP
	help
	  When enabled, the LWIP network stack is initialized only
	  once and subsequent calls reuse the existing descriptor.

endmenu

# ESP8266 Wi-Fi credentials. Kept outside the LWIP/W5500 menu above because the
# AT-command Wi-Fi transport does not use those stacks. Selected by a project's
# own networking option (e.g. IIO_DEMO_NETWORKING) so the WIFI_SSID / WIFI_PWD
# strings are only emitted for Wi-Fi builds, the same way NO_OS_IP is gated by
# NO_OS_STATIC_IP.
config WIFI_NETWORKING
	bool

config WIFI_SSID
	string "Wi-Fi SSID"
	depends on WIFI_NETWORKING
	default "RouterSSID"
	help
	  SSID of the access point the ESP8266 Wi-Fi module connects to.

config WIFI_PWD
	string "Wi-Fi password"
	depends on WIFI_NETWORKING
	default "******"
	help
	  Password for the WIFI_SSID access point.
