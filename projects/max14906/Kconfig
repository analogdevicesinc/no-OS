menu "MAX14906 Configuration"

choice MAX14906_EXAMPLE
	prompt "Example variant"
	default MAX14906_BASIC_EXAMPLE

config MAX14906_BASIC_EXAMPLE
	bool "Basic example"
	help
	  Basic example demonstrating MAX14906 digital I/O operations.

config MAX14906_IIO_EXAMPLE
	bool "IIO example"
	depends on IIO
	help
	  IIO example demonstrating MAX14906 as an IIO device.

endchoice

endmenu
