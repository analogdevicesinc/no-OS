menu "ADIS1657X Configuration"

choice ADIS1657X_EXAMPLE
	prompt "Example variant"
	default ADIS1657X_BASIC_EXAMPLE

config ADIS1657X_BASIC_EXAMPLE
	bool "Basic example"
	help
	  Simple example that initializes the ADIS1657X IMU and prints
	  measurements over UART.

config ADIS1657X_IIO_TRIGGER_EXAMPLE
	bool "IIO trigger example"
	depends on IIO && IRQ && GPIO
	help
	  Interrupt-driven IIO example using the ADIS1657X data-ready pin
	  as a hardware trigger.

endchoice

endmenu
