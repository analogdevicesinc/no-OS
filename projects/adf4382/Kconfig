menu "ADF4382 Configuration"

choice ADF4382_EXAMPLE
	prompt "Example variant"
	default ADF4382_BASIC_EXAMPLE

config ADF4382_BASIC_EXAMPLE
	bool "Basic example"
	help
	  Simple example that configures the ADF4382 PLL and prints
	  the resulting register state over UART.

config ADF4382_IIO_EXAMPLE
	bool "IIO example"
	depends on IIO
	help
	  IIO framework example. Launches an IIOD server for remote
	  data acquisition using IIO Oscilloscope or libiio clients.

endchoice

endmenu
