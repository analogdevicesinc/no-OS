menu "IIO ADPD1080 Configuration"

choice IIO_ADPD1080_EXAMPLE
	prompt "Example variant"
	default IIO_ADPD1080_IIO_EXAMPLE

config IIO_ADPD1080_IIO_EXAMPLE
	bool "IIO example"
	depends on IIO
	help
	  IIO example that exposes the ADPD1080/ADPD188 photometric front-end
	  over an IIO interface on top of a UART transport.

endchoice

config IIO_ADPD1080_NETWORKING
	bool "Enable ESP8266 Wi-Fi networking"
	default n
	select WIFI_NETWORKING
	help
	  Route IIO transport over an ESP8266 Wi-Fi module (UART AT commands)
	  instead of the serial backend. aducm3029/eval-adicup3029 only.

endmenu
