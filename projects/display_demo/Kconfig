menu "display_demo Configuration"

choice DISPLAY_DEMO_EXAMPLE
	prompt "Example variant"
	default DISPLAY_DEMO_DEMO_EXAMPLE

config DISPLAY_DEMO_DEMO_EXAMPLE
	bool "Demo"
	help
	  Demo that initializes the SSD1306 OLED display over SPI and prints
	  a message to the screen on the ZedBoard platform.

endchoice

endmenu
