 #endif
 		| ETHERNET_PROMISC_MODE;
 }
@@ -1507,6 +1764,34 @@ static int adin2111_init(const struct device *dev)
 	return ret;
 }
 
+#if defined(CONFIG_PTP_CLOCK)
+static const struct device *adin2111_get_ptp_clock(const struct device *dev)
+{
+	LOG_INF("🔍 adin2111_get_ptp_clock() called for device: %s", dev->name);
+
+	/* Find PTP clock device by compatible string */
+	const struct device *ptp_dev = device_get_binding("adi,adin1110-ptp-clock-0");
+	LOG_INF("🔍 device_get_binding result: %p", ptp_dev);
+
+	if (ptp_dev && device_is_ready(ptp_dev)) {
+		LOG_INF("✅ Found PTP device via binding: %s", ptp_dev->name);
+		return ptp_dev;
+	}
+
+	/* Alternative: try direct device tree lookup */
+	ptp_dev = DEVICE_DT_GET_OR_NULL(DT_INST(0, adi_adin1110_ptp_clock));
+	LOG_INF("🔍 DEVICE_DT_GET_OR_NULL result: %p", ptp_dev);
+
+	if (ptp_dev && device_is_ready(ptp_dev)) {
+		LOG_INF("✅ Found PTP device via DT: %s", ptp_dev->name);
+		return ptp_dev;
+	}
+
+	LOG_ERR("❌ No PTP clock device found");
+	return NULL;
+}
+#endif /* CONFIG_PTP_CLOCK */
