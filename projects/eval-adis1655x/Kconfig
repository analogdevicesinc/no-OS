menu "EVAL-ADIS1655X Configuration"

choice EVAL_ADIS1655X_EXAMPLE
	prompt "Example variant"
	default EVAL_ADIS1655X_BASIC_EXAMPLE

config EVAL_ADIS1655X_BASIC_EXAMPLE
	bool "Basic example"

config EVAL_ADIS1655X_IIO_TRIGGER_EXAMPLE
	bool "IIO Trigger example"
	depends on IIO && IRQ && GPIO

endchoice

endmenu
