menu "ad9467 Configuration"

choice AD9467_EXAMPLE
	prompt "Example variant"
	default AD9467_DEMO_EXAMPLE

config AD9467_DEMO_EXAMPLE
	bool "Demo example"
	help
	  Demo example that initializes the AD9467 ADC via AXI ADC core and
	  AXI DMA, runs pattern tests, and captures data to DDR.

config AD9467_IIO_EXAMPLE
	bool "IIO example"
	depends on IIO
	help
	  IIO example that exposes the AD9467 ADC through the IIO framework
	  via iio_axi_adc, enabling host-side data capture over UART.

endchoice

endmenu
