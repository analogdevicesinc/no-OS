menu "adrv9001 Configuration"

choice ADRV9001_EXAMPLE
	prompt "Example variant"
	default ADRV9001_DEMO_EXAMPLE

config ADRV9001_DEMO_EXAMPLE
	bool "Demo example"
	help
	  Basic initialization and bring-up example for the ADRV9001/ADRV9002
	  transceiver (2-channel mode) via AXI ADC/DAC cores and DMA.

config ADRV9001_DEMO_ADRV9002_EXAMPLE
	bool "Demo ADRV9002 RX2TX2 example"
	help
	  Basic initialization and bring-up example with ADRV9002 in RX2TX2
	  mode (4-channel), enabling both TX/RX channel pairs simultaneously.

config ADRV9001_DMA_EXAMPLE
	bool "DMA example"
	help
	  DMA-based data capture and playback example for the ADRV9001/ADRV9002
	  transceiver (2-channel mode).

config ADRV9001_IIO_EXAMPLE
	bool "IIO example"
	depends on IIO
	help
	  IIO example that exposes the ADRV9001/ADRV9002 transceiver (2-channel
	  mode) through the IIO framework via iio_axi_adc and iio_axi_dac,
	  enabling host-side data capture and playback over UART.

config ADRV9001_IIO_ADRV9002_EXAMPLE
	bool "IIO ADRV9002 RX2TX2 example"
	depends on IIO
	help
	  IIO example with ADRV9002 in RX2TX2 mode (4-channel). Exposes both
	  TX/RX channel pairs through the IIO framework over UART.

endchoice

endmenu
