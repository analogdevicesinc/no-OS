menu "IIO Demo Configuration"

choice IIO_DEMO_EXAMPLE
	prompt "Example variant"
	default IIO_DEMO_IIO_EXAMPLE

config IIO_DEMO_IIO_EXAMPLE
	bool "Basic IIO example"

config IIO_DEMO_IIO_TIMER_TRIGGER_EXAMPLE
	bool "IIO timer trigger example"

config IIO_DEMO_IIO_SW_TRIGGER_EXAMPLE
	bool "IIO software trigger example"

endchoice

config IIO_DEMO_USB_UART
	bool "Use USB CDC as UART transport"
	default n
	help
	  Use USB CDC ACM instead of a hardware UART for the IIO
	  communication channel. Requires a USB CDC capable board
	  and the platform USB UART driver.

endmenu
