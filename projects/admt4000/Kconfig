menu "ADMT4000 Configuration"

choice ADMT4000_EXAMPLE
	prompt "Example variant"
	default ADMT4000_BASIC_EXAMPLE

config ADMT4000_BASIC_EXAMPLE
	bool "Basic example"

config ADMT4000_IIO_TRIGGER_EXAMPLE
	bool "IIO Trigger example"
	depends on IIO && IRQ

endchoice

config PCL_VERSION
	string "precision-converters-library version tag/commit"
	default "7af7d492b075538d11534f0db11e005c930b804c"
	depends on ADMT4000_IIO_TRIGGER_EXAMPLE
	help
	  Git tag, branch or commit for precision-converters-library.
	  Checked against the submodule, then the shared cache, then fetched.

config ADMT4000_TMC5240
	bool "Enable TMC5240 motor driver support"
	depends on ADMT4000_IIO_TRIGGER_EXAMPLE
	default n
	help
	  Enable Trinamic TMC5240 stepper motor driver support in IIO trigger example.

endmenu
