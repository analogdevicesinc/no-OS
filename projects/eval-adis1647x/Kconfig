menu "ADIS1647X Configuration"

choice ADIS1647X_EXAMPLE
	prompt "Example variant"
	default ADIS1647X_BASIC_EXAMPLE

config ADIS1647X_BASIC_EXAMPLE
	bool "Basic example"
	help
	  Simple example that initializes the ADIS1647X IMU and prints
	  measurements over UART.

config ADIS1647X_IIO_TRIGGER_EXAMPLE
	bool "IIO trigger example"
	depends on IIO && IRQ && GPIO
	help
	  Interrupt-driven IIO example using the ADIS1647X data-ready pin
	  as a hardware trigger.

endchoice

endmenu
