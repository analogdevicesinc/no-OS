menu "ADIS1650X Configuration"

choice ADIS1650X_EXAMPLE
	prompt "Example variant"
	default ADIS1650X_BASIC_EXAMPLE

config ADIS1650X_BASIC_EXAMPLE
	bool "Basic example"
	help
	  Simple example that initializes the ADIS1650X IMU and prints
	  measurements over UART.

config ADIS1650X_IIO_TRIGGER_EXAMPLE
	bool "IIO trigger example"
	depends on IIO && IRQ && GPIO
	help
	  Interrupt-driven IIO example using the ADIS1650X data-ready pin
	  as a hardware trigger.

endchoice

endmenu
