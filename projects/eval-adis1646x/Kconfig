menu "ADIS1646X Configuration"

choice ADIS1646X_EXAMPLE
	prompt "Example variant"
	default ADIS1646X_BASIC_EXAMPLE

config ADIS1646X_BASIC_EXAMPLE
	bool "Basic example"
	help
	  Simple example that initializes the ADIS1646X IMU and prints
	  measurements over UART.

config ADIS1646X_IIO_TRIGGER_EXAMPLE
	bool "IIO trigger example"
	depends on IIO && IRQ && GPIO
	help
	  Interrupt-driven IIO example using the ADIS1646X data-ready pin
	  as a hardware trigger.

endchoice

endmenu
