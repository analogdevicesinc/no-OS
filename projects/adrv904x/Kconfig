menu "adrv904x Configuration"

choice ADRV904X_EXAMPLE
	prompt "Example variant"
	default ADRV904X_BASIC_EXAMPLE

config ADRV904X_BASIC_EXAMPLE
	bool "Basic example"
	help
	  Basic initialization and bring-up example for the ADRV904X
	  transceiver via JESD204 RX/TX, AXI ADC/DAC cores, and DMA.

config ADRV904X_DMA_EXAMPLE
	bool "DMA example"
	help
	  DMA-based data capture and playback example for the ADRV904X
	  transceiver.

config ADRV904X_IIO_EXAMPLE
	bool "IIO example"
	depends on IIO
	help
	  IIO example that exposes the ADRV904X transceiver through the IIO
	  framework via iio_axi_adc and iio_axi_dac, enabling host-side data
	  capture and playback over UART.

endchoice

endmenu
